{
  "name": "@mrbone11/deepdive",
  "version": "0.1.2",
  "description": "DeepSeek-native terminal coding agent",
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "bin": {
    "deepdive": "dist/cli.js"
  },
  "files": [
    "dist/"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/senweiliang/DeepDive.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/cli.tsx",
    "dev:compact": "DEEPSEEK_CONTEXT_WINDOW=3000 tsx src/cli.tsx",
    "build": "rm -rf dist && tsc && node scripts/postbuild.js",
    "prepublishOnly": "pnpm run build",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "deepseek",
    "tui",
    "coding-agent",
    "terminal"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "figlet": "^1.11.0",
    "ink": "^7.0.2",
    "lowlight": "^3.3.0",
    "marked": "^18.0.3",
    "react": "^19.2.6",
    "string-width": "^8.2.1",
    "undici": "^8.3.0"
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
